# ════════════════════════════════════════════════════════════
# LOPANGO — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Dans Coolify : configurer ces variables dans l'interface
# ════════════════════════════════════════════════════════════

# ── APPLICATION ───────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://lopango.bakapdatalabs.com

# ── BASE DE DONNÉES (générées par Coolify si service MySQL ajouté) ────────
DB_HOST=db
DB_NAME=lopango
DB_USER=lopango
DB_PASS=CHANGER_CE_MOT_DE_PASSE
DB_ROOT_PASS=CHANGER_CE_MOT_DE_PASSE_ROOT
